# ============================================
# 终末地抽卡分析器 - 外部贡献者安全环境变量模板
# ============================================
# 用途:
# - 给外部贡献者本地运行前端、查看公开页面、调用公开读取链路。
# - 只包含浏览器端本来就会公开的 VITE_* 变量。
#
# 使用方法:
# 1. 复制为 .env.local
# 2. 向维护者索取“公开 publishable/anon key”，填入 VITE_SUPABASE_PUBLISHABLE_KEY
# 3. npm install
# 4. npm run dev
#
# 安全边界:
# - 不要在这个文件里填写 SUPABASE_SECRET_KEY、SUPABASE_SERVICE_ROLE_KEY、SUPABASE_JWT_SECRET。
# - 不要填写 SMTP 密码、OAuth Client Secret、BOT token、Cron secret、CAPTCHA secret。
# - 如果你需要调试后台、邮件、运营自动化或私有写入任务，请使用本地 Supabase 或联系维护者开临时最小权限环境。

# ====== 本地站点 ======
VITE_APP_URL=http://127.0.0.1:5173

# ====== 公开 Supabase 读取配置 ======
# 这是站点自建数据库的公开 API 域名。只能配合 publishable/anon key 和 RLS 访问公开或本人授权的数据。
VITE_SUPABASE_URL=https://db.15963574.xyz

# 由维护者提供。该 key 允许出现在浏览器中，但必须是受 RLS 限制的低权限公开 key。
VITE_SUPABASE_PUBLISHABLE_KEY=
# 旧版兼容别名；一般不用填。
# VITE_SUPABASE_ANON_KEY=

# 生产首屏默认走同源 /api。贡献者本地不要默认启用浏览器直连 Supabase 的公共数据回退。
VITE_PUBLIC_DATA_DIRECT_SUPABASE_FALLBACK=false

# 关闭 Realtime，避免外部贡献者本地因为网络或权限看到 WebSocket 超时。
VITE_SUPABASE_REALTIME_ENABLED=false

# ====== 私有导入代理 ======
# 官方导入代理不随公开仓库提供。留空时，只能测试不依赖私有代理的公开页面和 UI。
VITE_PROXY_URL_CN=
VITE_PROXY_URL_INTL=

# ====== 验证码前端开关 ======
# 默认关闭。需要测试验证码 UI 时，贡献者应使用自己的 Turnstile / hCaptcha site key。
VITE_AUTH_CAPTCHA_MODE=off
VITE_AUTH_CAPTCHA_PROVIDER=turnstile
VITE_AUTH_CAPTCHA_REQUIRED_ACTIONS=register,password_reset,account_recovery
VITE_AUTH_CAPTCHA_SITE_KEY=
VITE_TURNSTILE_SITE_KEY=
VITE_HCAPTCHA_SITE_KEY=

# ====== 第三方登录按钮 ======
# 默认关闭。GitHub / Linux.do / QQ 的真实 Client Secret 只放服务端环境变量，不进入 VITE_*。
VITE_AUTH_OAUTH_GITHUB_ENABLED=false
VITE_AUTH_OAUTH_LINUXDO_ENABLED=false
VITE_AUTH_OAUTH_QQ_ENABLED=false

# ====== 可选公开入口 ======
VITE_PUZZLE_PLAYER_URL=

# 本地开发缓存标记。需要强制浏览器刷新缓存时可手动改一个新值。
VITE_APP_FORCE_REFRESH_TOKEN=local-contributor
