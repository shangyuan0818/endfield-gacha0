!supabase/archive/**
scratch/
coverage/
test-results/
*.tmp
*.bak

# Backend services / 抓取链路（因合规与版权风险保留私有，不进入公开仓库）
# Shared backend library files that are imported by tests/runtime are explicitly re-included below.
backend/*
!backend/lib/
backend/lib/*
!backend/lib/canonicalEntityUtils.js
!backend/lib/idAliasService.js
!backend/lib/officialIdReconciliation.js
!backend/lib/officialImportIncremental.js
dev-proxy.js
api/hg-proxy.js

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
docs/email-template/twilio_2FA_recovery_code.txt
.vercel
.env*.local

# Local Judou Sans source files stay out of version control.
src/assets/fonts/judou/*.zip
src/assets/fonts/judou/*.ttf
!src/assets/fonts/judou/OFL.txt

# Harmony SC subsets are generated from checked-in woff2 sources during predev/prebuild.
src/generated/fonts/harmony/

# Retired Judou subsets are not referenced by the app font entrypoint.
src/generated/fonts/judou/

bots/*
!bots/official/
!bots/official/**
backend/lib/canonicalEntityUtils.js
backend/lib/idAliasService.js
