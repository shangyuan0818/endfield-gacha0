{
  "name": "endfield-gacha-analyzer",
  "description": "终末地抽卡分析器 - 《明日方舟：终末地》抽卡记录分析工具",
  "private": true,
  "version": "3.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "dev:backend:cn": "npm --prefix backend run dev:cn",
    "dev:backend:intl": "npm --prefix backend run dev:intl",
    "dev:proxy": "node scripts/private-proxy-notice.mjs",
    "dev:full": "npm run dev:proxy && npm run dev",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\"",
    "preview": "vite preview",
    "test:harness": "node backend/test-harness/run-suite.js",
    "test:simulator-inheritance": "node scripts/verify-simulator-inheritance.mjs",
    "test:resource-ui": "node scripts/verify-resource-ui-playwright.mjs",
    "audit:canonical-data": "node scripts/audit-canonical-data.mjs",
    "generate:supabase-baseline": "node scripts/generate-supabase-baseline.mjs",
    "generate:alias-merge-sql": "node scripts/generate-alias-merge-sql.mjs",
    "generate:legacy-id-alias-seed": "node scripts/generate-legacy-id-alias-seed.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.86.0",
    "@uiw/react-md-editor": "^4.0.11",
    "canvas-confetti": "^1.9.4",
    "dompurify": "^3.3.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^2.2.3",
    "recharts": "^3.5.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.17",
    "vite": "^7.2.4"
  }
}
