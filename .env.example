# ============================================
# 终末地抽卡分析器 - 环境变量配置示例
# ============================================
# 使用方法:
# 1. 复制此文件并重命名为 .env / .env.local
# 2. 填写下面的实际配置值
# 3. 重启开发服务器使配置生效
# 4. 若本地 dev middleware 需要读取服务端密钥，也可放在 backend/.env.local

# ====== Supabase 配置 (必需) ======
# 获取方式: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxx       # legacy alias
SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx          # legacy alias

# ====== 应用配置 (必需) ======
# 应用的公开访问域名，用于:
# 1. Auth 回跳 / 浏览器端链接生成
# 2. "急"按钮实时同步功能
# 3. 本地 dev middleware / Serverless allow-origin
VITE_APP_URL=https://your-domain.vercel.app

# 生产环境公共数据默认只走同源 /api。
# 若本地开发或应急回退仍需要浏览器直连 Supabase，可显式打开：
VITE_PUBLIC_DATA_DIRECT_SUPABASE_FALLBACK=false

# 浏览器端 Realtime 默认关闭，避免本地/无代理网络出现 Supabase WebSocket 超时。
# 仅在需要调试角色/卡池实时订阅，并确认网络能直连 Supabase Realtime 时开启。
VITE_SUPABASE_REALTIME_ENABLED=false

# 邮件防刷 HMAC 盐，仅服务端使用。不要暴露给前端。
# 未配置时本地开发会回退到 SUPABASE_JWT_SECRET 或本地默认盐；生产环境应显式设置。
MAIL_ABUSE_HASH_SECRET=replace-me-with-long-random-secret

# 自建邮件平台配置。默认按 Stalwart 优先规划。
# 当前已有 outbox 队列处理器 / provider adapter 边界，但默认使用演练模式，不发送真实邮件。
# 不要在公开仓库提交真实 SMTP/JMAP 凭据、DKIM 私钥或服务器 IP。
MAIL_PROVIDER=stalwart
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=Endfield Gacha
# 注册确认、密码重置、邮件登录的同源 Auth 邮件入口。
# 真实发信前必须同时完成 CAPTCHA / 限流 / 紧急停发开关 / Stalwart SMTP 配置。
AUTH_MAIL_ACTIONS_ENABLED=false
ACCOUNT_RECOVERY_MAIL_OUTBOX_ENABLED=false
# 开发者 API 审核结果通知。需要同时启用 MAIL_OUTBOX_WORKER_ENABLED；默认关闭。
DEVELOPER_API_REVIEW_MAIL_OUTBOX_ENABLED=false
# 工单 staff 回复邮件通知。需要同时启用 MAIL_OUTBOX_WORKER_ENABLED；默认关闭。
TICKET_REPLY_MAIL_OUTBOX_ENABLED=false
# 管理员受控自告警邮件。只允许发送给当前 super_admin 自己；默认关闭。
ADMIN_ALERT_MAIL_OUTBOX_ENABLED=false
MAIL_OUTBOX_WORKER_ENABLED=false
MAIL_WORKER_DRY_RUN=true
MAIL_WORKER_BATCH_SIZE=10
MAIL_WORKER_MAX_ATTEMPTS=3
MAIL_WORKER_RETRY_DELAY_SECONDS=900
MAIL_PROVIDER_TIMEOUT_MS=15000
MAIL_OUTBOX_GLOBAL_KILL_SWITCH=true
# 内部队列处理 endpoint secret。/api/mail-outbox-worker 同时接受此值和 CRON_SECRET，
# 方便 Vercel Cron 使用 Authorization: Bearer <CRON_SECRET> 触发；生产仍建议单独设置此值给外部 cron / 运维脚本。
MAIL_OUTBOX_WORKER_SECRET=
STALWART_SMTP_HOST=
STALWART_SMTP_PORT=587
STALWART_SMTP_USERNAME=
STALWART_SMTP_PASSWORD=
STALWART_SMTP_SECURE=false
STALWART_SMTP_STARTTLS=true
STALWART_SMTP_TLS_REJECT_UNAUTHORIZED=true
STALWART_SMTP_ALLOW_INSECURE=false
STALWART_JMAP_URL=
STALWART_WEBHOOK_SECRET=
# 内部投递反馈 / 退信回写 secret。可与 STALWART_WEBHOOK_SECRET 分开；不要暴露给前端。
MAIL_DELIVERY_WEBHOOK_SECRET=
# 内部入站邮件事件 secret。用于 Stalwart Webhooks / MTA Hooks 调用 /api/mail-inbound。
MAIL_INBOUND_WEBHOOK_SECRET=
# Postal 是后续独立邮件 VPS / 事务邮件平台化的备选，不是当前同机部署默认。
POSTAL_API_URL=
POSTAL_API_KEY=
POSTAL_SMTP_HOST=
POSTAL_SMTP_PORT=587
POSTAL_SMTP_USERNAME=
POSTAL_SMTP_PASSWORD=
POSTAL_WEBHOOK_SECRET=
# SMTP EHLO / Message-ID domain. Prefer the mail host with matching A/PTR, e.g. mail.example.com.
MAIL_SENDING_DOMAIN=mail.example.com

# 认证安全审计 / 风险识别 HMAC 盐，仅服务端使用。生产环境建议显式设置。
# 未配置时会回退到 MAIL_ABUSE_HASH_SECRET / SUPABASE_JWT_SECRET。
AUTH_SECURITY_HASH_SECRET=replace-me-with-long-random-secret

# 登录 / 注册 / 恢复申请的服务端 CAPTCHA 策略。
# off: 不校验；monitor: 记录风险但不拦截；enforce: 对 AUTH_CAPTCHA_REQUIRED_ACTIONS 强制校验。
# provider 支持 turnstile / hcaptcha；secret 只放服务端环境变量。
AUTH_CAPTCHA_MODE=off
AUTH_CAPTCHA_PROVIDER=turnstile
AUTH_CAPTCHA_REQUIRED_ACTIONS=register,password_reset,account_recovery
AUTH_CAPTCHA_SECRET_KEY=

# 浏览器端只允许放 CAPTCHA site key；不要放 secret。
# 与服务端策略保持同一 action 列表。生产开启 enforce 前需要真实 provider token 能透传到 /api/auth-rate-limit。
VITE_AUTH_CAPTCHA_MODE=off
VITE_AUTH_CAPTCHA_PROVIDER=turnstile
VITE_AUTH_CAPTCHA_REQUIRED_ACTIONS=register,password_reset,account_recovery
VITE_AUTH_CAPTCHA_SITE_KEY=
VITE_TURNSTILE_SITE_KEY=
VITE_HCAPTCHA_SITE_KEY=

# 第三方一键登录。GitHub 由自建 Supabase Auth 生成真实登录态；
# Linux.do 的 custom provider 支持已预留，但需要先确认当前 Auth 服务识别；
# QQ 暂时保留本站同源桥接，等 QQ 应用审核和真实回调验证后再开放。
# 所有 CLIENT_SECRET / App Key 只放服务端或 Supabase Auth 容器环境变量；
# 浏览器端只用 VITE_AUTH_OAUTH_*_ENABLED 控制按钮显示。
#
# 自建 Supabase Auth 容器侧示例：
# GOTRUE_EXTERNAL_GITHUB_ENABLED=true
# GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=<GitHub Client ID>
# GOTRUE_EXTERNAL_GITHUB_SECRET=<GitHub Client Secret>
# GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI=https://db.example.com/auth/v1/callback
# GOTRUE_SECURITY_MANUAL_LINKING_ENABLED=true
# Linux.do 使用 Supabase Custom OAuth/OIDC provider，provider id 建议 custom:linuxdo，
# issuer=https://connect.linux.do/，scope=openid profile email，按实际测试启用 email_optional。
# 只有 /auth/v1/settings 或 authorize 实测识别该 provider 后，才把 VITE_AUTH_OAUTH_LINUXDO_READY=true。
OAUTH_STATE_SECRET=replace-me-with-long-random-secret
AUTH_OAUTH_LINUXDO_ENABLED=false
AUTH_OAUTH_LINUXDO_CLIENT_ID=
AUTH_OAUTH_LINUXDO_CLIENT_SECRET=
AUTH_OAUTH_LINUXDO_REDIRECT_URI=https://your-domain.vercel.app/api/auth/oauth/linuxdo/callback
AUTH_OAUTH_LINUXDO_SCOPE=openid profile email
VITE_AUTH_OAUTH_LINUXDO_ENABLED=false
VITE_AUTH_OAUTH_LINUXDO_READY=false

AUTH_OAUTH_GITHUB_ENABLED=false
AUTH_OAUTH_GITHUB_BRIDGE_ENABLED=false
AUTH_OAUTH_GITHUB_CLIENT_ID=
AUTH_OAUTH_GITHUB_CLIENT_SECRET=
AUTH_OAUTH_GITHUB_REDIRECT_URI=https://your-domain.vercel.app/api/auth/oauth/github/callback
AUTH_OAUTH_GITHUB_SCOPE=read:user user:email
VITE_AUTH_OAUTH_GITHUB_ENABLED=false

AUTH_OAUTH_QQ_ENABLED=false
AUTH_OAUTH_QQ_CLIENT_ID=
AUTH_OAUTH_QQ_CLIENT_SECRET=
AUTH_OAUTH_QQ_REDIRECT_URI=https://your-domain.vercel.app/api/auth/oauth/qq/callback
AUTH_OAUTH_QQ_SCOPE=get_user_info
VITE_AUTH_OAUTH_QQ_ENABLED=false

# 可选认证风险域名规则，逗号分隔。只影响同源 API 的服务端风险桶 / 审计。
AUTH_RISK_HIGH_EMAIL_DOMAINS=
AUTH_RISK_BLOCKED_EMAIL_DOMAINS=

# 账号恢复人工降级链：管理员发放临时密码后的有效期，单位小时。
# 默认 24，服务端最多接受 168。
ACCOUNT_RECOVERY_TEMP_PASSWORD_TTL_HOURS=24

# 发布时如需强制所有访客刷新一次公共快照，可 bump 这个 token
VITE_APP_FORCE_REFRESH_TOKEN=2026-05-22-release-refresh

# ====== 可选配置 ======

# 外部代理服务器地址（可选）
# 如果不配置，将走站内 Serverless / 本地 dev middleware；完整导入能力仍取决于你的私有代理是否可用
#
# 单后端模式示例: https://endfield-proxy.railway.app
# VITE_PROXY_URL=https://your-backend-server.railway.app
#
# 双后端模式示例（推荐用于国服 / 国际服分离部署）
# VITE_PROXY_URL_CN=https://your-cn-backend.railway.app
# VITE_PROXY_URL_INTL=https://your-intl-backend.railway.app
VITE_PROXY_URL_CN=https://your-cn-proxy.example.com
VITE_PROXY_URL_INTL=https://your-intl-proxy.example.com

# 验证码玩家站（可选）
# 若未配置，将回退到站内默认路径或隐藏对应跳转
VITE_PUZZLE_PLAYER_URL=https://your-puzzle-player.example.com

# ====== 公共自动化与 Cron（可选） ======

# Vercel Cron 鉴权 secret
CRON_SECRET=replace-me

# OPS-006：官方公告 / 卡池 / 图鉴巡检源
OPS_AUTOMATION_ANNOUNCEMENTS_URL=https://example.com/announcements.json
OPS_AUTOMATION_ANNOUNCEMENTS_TAG=official-json
OPS_AUTOMATION_POOL_SCHEDULE_URL=https://example.com/pools.json
OPS_AUTOMATION_POOL_SCHEDULE_TAG=official-json
OPS_AUTOMATION_WIKI_CATALOG_URL=https://example.com/wiki.json
OPS_AUTOMATION_WIKI_CATALOG_TAG=official-json

# ====== 官方 BOT（可选） ======

# 官方 Telegram BOT
TELEGRAM_OFFICIAL_BOT_PUBLIC_API_KEY=replace-me
TELEGRAM_OFFICIAL_BOT_VERIFIER_SECRET=replace-me
TELEGRAM_OFFICIAL_BOT_TOKEN=replace-me
TELEGRAM_OFFICIAL_BOT_PROXY_URL=http://127.0.0.1:7890
TELEGRAM_OFFICIAL_BOT_POLL_INTERVAL_MS=1500
TELEGRAM_OFFICIAL_BOT_LONG_POLL_SECONDS=20

# ====== 后端可选变量（部署私有 backend/ 时使用） ======

# TG_BOT_TOKEN=your-telegram-bot-token
# TG_CHAT_ID=your-default-chat-id
# TG_API_BASE=https://api.telegram.org
#
# 双后端推荐分别设置独立群/频道，避免国服和国际服混发
# TG_CHAT_ID_CN=-100xxxxxxxxxx
# TG_CHAT_ID_INTL=-100yyyyyyyyyy
# TG_CHAT_ID_ALL=-100zzzzzzzzzz
#
# Telegram 告警节流窗口（毫秒）
# TG_ALERT_THROTTLE_MS=180000
#
# 后端日志时区，影响服务端 console 时间戳
# LOG_TIMEZONE=Asia/Shanghai

# ============================================
# 📌 重要提示
# ============================================
#
# 1. Supabase 配置:
#    - 确保已创建所有必需的数据库表和迁移
#    - 当前新环境优先直接执行 supabase/baseline/000_complete_schema.sql
#    - baseline 已覆盖到 active/120_add_mail_outbox_enqueue_rpc.sql
#    - 若要在本地调试账号恢复 / bootstrap / 受限管理接口，还必须额外配置 SUPABASE_SECRET_KEY
#
# 2. Realtime 功能:
#    - 浏览器端默认不建立 Realtime WebSocket；公共首屏数据通过同源 /api 和快照刷新。
#    - 需要调试角色 / 卡池实时订阅时，设置 VITE_SUPABASE_REALTIME_ENABLED=true。
#    - 若开启，还需在 Supabase Dashboard -> Database -> Replication 中启用对应表。
#
# 3. 账号恢复 / 自建邮件:
#    - 注册确认、密码重置和邮件登录走同源 /api/auth-email-action，默认 AUTH_MAIL_ACTIONS_ENABLED=false
#    - 开启认证邮件前必须配置 Stalwart SMTP、AUTH_CAPTCHA_MODE / site key、紧急停发开关和投递监控
#    - 账号恢复优先走自助密码重置邮件；多次收不到邮件或邮箱不可用时才提交人工恢复申请
#    - 只有 ACCOUNT_RECOVERY_MAIL_OUTBOX_ENABLED=true 且 MAIL_OUTBOX_WORKER_ENABLED=true 时，人工恢复申请中的 password_reset 才会写入 mail_outbox
#    - 开发者 API 审核通知由 DEVELOPER_API_REVIEW_MAIL_OUTBOX_ENABLED 控制；入队失败不阻断审核
#    - 工单 staff 回复通知由 TICKET_REPLY_MAIL_OUTBOX_ENABLED 控制；管理员自告警由 ADMIN_ALERT_MAIL_OUTBOX_ENABLED 控制
#    - 临时密码状态写入私有 account_security_states；用户登录后需在设置页改密
#    - auth_security_events 只保存 hash、风险桶和脱敏摘要，不保存原始邮箱 / 密码 / CAPTCHA token / game_uid
#    - AUTH_CAPTCHA_MODE=enforce 前必须先接入真实 Turnstile / hCaptcha 前端 token，否则注册 / 恢复会被服务端拦截
#    - 自建邮件主线详见 docs/SELF_HOSTED_MAIL.md；当前只有认证邮件入口允许受控同步发信，不提供通用公开发送邮件 API
#    - 邮件入队使用 MAIL_ABUSE_HASH_SECRET 生成收件人 hash、预算桶 key 和幂等 key
#    - MAIL_WORKER_DRY_RUN=true 表示演练模式：只验证队列处理 / 模板 / 状态回写，不代表真实投递
#    - MAIL_WORKER_DRY_RUN=false 前必须完成真实传输、DNS、suppression、紧急停发开关和投递监控
#    - 若要让国服 / 国际服后端分别推送到不同 Telegram 群，请同时配置 TG_CHAT_ID_CN / TG_CHAT_ID_INTL
#
# 4. Edge Functions:
#    - 旧 admin-create-user / admin-delete-user 仅保留兼容说明
#    - 当前后台主链已收口到 Vercel Serverless `/api/admin`
#
# ============================================
