# ============================================
# 终末地抽卡分析器 - 环境变量配置示例
# ============================================
# 使用方法:
# 1. 复制此文件并重命名为 .env / .env.local
# 2. 填写下面的实际配置值
# 3. 重启开发服务器使配置生效
# 4. 若本地 dev middleware 需要读取服务端密钥，也可放在 backend/.env.local

# ====== Supabase 配置 (必需) ======
# 获取方式: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 服务端管理密钥（账号恢复 / 受限后端接口需要）
# 仅供本地 dev middleware / 服务端函数读取，不能在前端代码里使用 import.meta.env 暴露给浏览器
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ====== 应用配置 (必需) ======
# 应用的公开访问域名，用于:
# 1. Auth 回跳 / 浏览器端链接生成
# 2. "急"按钮实时同步功能
# 3. 本地 dev middleware / Serverless allow-origin
#
# 开发环境示例: http://localhost:5173
# 生产环境示例: https://your-domain.vercel.app
VITE_APP_URL=https://your-domain.vercel.app

# ====== 可选配置 ======

# 外部代理服务器地址（可选）
# 如果不配置，将走站内 Serverless / 本地 dev middleware；完整导入能力仍取决于你的私有代理是否可用
#
# 部署方式：
# 1. Railway: 将 backend/ 目录部署到 Railway
# 2. Render: 使用 backend/render.yaml 配置
# 3. 自建 VPS: 运行 backend/server.js
#
# 单后端模式示例: https://endfield-proxy.railway.app
# VITE_PROXY_URL=https://your-backend-server.railway.app

# 双后端模式示例（推荐用于国服 / 国际服分离部署）
# VITE_PROXY_URL_CN=https://your-cn-backend.railway.app
# VITE_PROXY_URL_INTL=https://your-intl-backend.railway.app

# 验证码玩家站（可选）
# 若未配置，将回退到站内默认路径或隐藏对应跳转
# VITE_PUZZLE_PLAYER_URL=https://your-puzzle-player.example.com

# ====== 后端可选变量（部署私有 backend/ 时使用） ======

# Telegram 通知基础配置
# TG_BOT_TOKEN=your-telegram-bot-token
# TG_CHAT_ID=your-default-chat-id
# TG_API_BASE=https://api.telegram.org

# 双后端推荐分别设置独立群/频道，避免国服和国际服混发
# 国服后端（HG_BACKEND_SOURCE=cn）优先读取 TG_CHAT_ID_CN
# 国际服后端（HG_BACKEND_SOURCE=intl）优先读取 TG_CHAT_ID_INTL
# 混合后端（HG_BACKEND_SOURCE=all）优先读取 TG_CHAT_ID_ALL
# 若对应变量未配置，才回退到 TG_CHAT_ID
# TG_CHAT_ID_CN=-100xxxxxxxxxx
# TG_CHAT_ID_INTL=-100yyyyyyyyyy
# TG_CHAT_ID_ALL=-100zzzzzzzzzz

# Telegram 告警节流窗口（毫秒）
# 同类错误会在该窗口内合并，避免短时间内连续刷屏
# TG_ALERT_THROTTLE_MS=180000

# 后端日志时区，影响服务端 console 时间戳
# LOG_TIMEZONE=Asia/Shanghai

# ============================================
# 📌 重要提示
# ============================================
#
# 1. Supabase 配置:
#    - 确保已创建所有必需的数据库表和迁移
#    - 当前新环境优先直接执行 supabase/migrations/ 中的标准迁移
#    - baseline 仍待重新生成，不建议和完整迁移链叠加执行
#    - 若要在本地调试“账号恢复 / bootstrap / 受限管理接口”，还必须额外配置 SUPABASE_SERVICE_ROLE_KEY
#
# 2. Realtime 功能:
#    - 在 Supabase Dashboard -> Database -> Replication 中
#    - 启用 global_stats 表的 Realtime 开关
#    - 这对"急"按钮实时统计功能是必需的
#
# 3. 账号恢复 / SMTP:
#    - 账号恢复当前不走邮件重置，而是“提交恢复申请 -> 超管核验 -> 临时密码线下发放”
#    - 临时密码当前统一通过 QQ 群 1080983185 线下发放
#    - 若你仍需要邮箱注册确认等邮件能力，再额外配置 SMTP
#    - 若要让国服 / 国际服后端分别推送到不同 Telegram 群，请同时配置 TG_CHAT_ID_CN / TG_CHAT_ID_INTL
#
# 4. Edge Functions (超管功能需要):
#    - admin-create-user: 创建新用户
#    - admin-delete-user: 删除用户
#    - 部署到 Supabase 的 Edge Functions 目录
#
# ============================================
